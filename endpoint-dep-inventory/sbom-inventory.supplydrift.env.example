# SupplyDrift platform configuration for collect-sbom-inventory.sh.
#
# Point the collector at the platform's endpoint-sync API. The platform accepts
# the collector's native batch format directly (gzip + Bearer supported), so no
# payload adapter is needed. Configure the URL and authentication below.
#
# Precedence: built-in defaults < this config file < environment variables < CLI flags.
# Exported SBOM_* environment variables always override values set here.
#
# Do not run this checked-in template directly: repository file permissions are
# too open for a token-bearing config under strict defaults. Copy it to a private
# directory, chmod the copy and token file to 600, edit the paths/values, and run
# the protected copy. See README.md -> SupplyDrift Platform.

# Real uploads are enabled. Set true only to print payloads without uploading.
SBOM_DRY_RUN=false

# The platform's endpoint-sync endpoint (note the path — it is the full URL).
# This local-dev example talks to the platform over plaintext http, which the
# collector refuses by default — set SBOM_ALLOW_INSECURE=true (below) to allow it.
# For any remote/production server use https:// instead.
SBOM_SERVER_URL="http://127.0.0.1:8765/api/sync/endpoints"
SBOM_ALLOW_INSECURE=true
# Authentication is enabled by default. Create an API token with `ingest` scope
# under Access -> API tokens, write only that token to a mode-600 file, and set
# the protected path here. For a one-off test, SBOM_AUTH_TOKEN can be supplied
# through the environment instead; do not commit a real token to this file.
SBOM_AUTH_TOKEN_FILE="/etc/sbom-inventory/token"

# Gzip is supported by the platform; keep it on to save bandwidth.
SBOM_COMPRESS_UPLOAD=true

# Vulnerability scanning: grype runs on the syft SBOM and uploads a SEPARATE,
# tiny vulnerability batch (package name/version/purl + CVE id/severity/fix) to
# the same endpoint. Requires grype on the device. Set false to ship SBOM only.
SBOM_ENABLE_VULN_SCAN=true
# SBOM_GRYPE_BIN=grype
# SBOM_VULN_BATCH_SIZE=1000
# SBOM_GRYPE_DB_AUTO_UPDATE=true   # set false to use a pre-staged grype DB

# Frequent-run optimization: when nothing dependency-relevant changed, the run
# skips syft and sends one tiny `payload_type: "heartbeat"` JSON instead. The
# current SupplyDrift adapter accepts heartbeats but does not persist their
# liveness fields. Inventory coverage still comes from the forced full scan every
# SBOM_FULL_SCAN_INTERVAL_HOURS.
SBOM_CHANGE_GATE=true
SBOM_FULL_SCAN_INTERVAL_HOURS=168
# SBOM_HEARTBEAT_ON_UNCHANGED=true

# Local state + scan scope (see sbom-inventory.env.example for the full set).
SBOM_STATE_DIR="$HOME/.sbom-inventory"
SBOM_SOURCE_NAME="developer-endpoint"
# Default scope is user homes; switch both to fullfs when scanning "/".
SBOM_SCAN_POLICY_VERSION="homes-v1"
# SBOM_SCAN_ROOTS="/"
SBOM_BATCH_SIZE=500

# For a quick local test against the checked-in fixtures instead of a full FS scan:
# SBOM_SCAN_ROOTS="$PWD/test-manifests"
# SBOM_EXCLUDE_PATHS=""
# SBOM_BATCH_SIZE=4
# SBOM_START_JITTER_SECONDS=0
# SBOM_SKIP_ON_BATTERY=false
