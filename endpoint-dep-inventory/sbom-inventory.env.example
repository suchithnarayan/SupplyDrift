# Example production configuration for collect-sbom-inventory.sh.
#
# This file is plain KEY=VALUE (no logic). It is sourced by Bash, so values
# may quote $HOME-style variables, but keep it declarative.
# Precedence: built-in defaults < this config file < environment variables < CLI flags.
# Exported SBOM_* environment variables always override values set here.
#
# Run:
#   ./collect-sbom-inventory.sh --config ./sbom-inventory.env.example
#
# For production, copy this file to a protected path such as:
#   /etc/sbom-inventory/config.env

# Keep dry-run enabled in the checked-in example. Set false for real uploads.
SBOM_DRY_RUN=false

# Required for real uploads when SBOM_DRY_RUN=false.
# Use https:// for any remote server — the upload carries the bearer token and the
# full inventory. A plaintext http:// URL (e.g. local dev below) is refused unless
# you also set SBOM_ALLOW_INSECURE=true.
SBOM_SERVER_URL="https://supplydrift.example.com/api/sync/endpoints"
# Local dev against the platform over http needs: SBOM_ALLOW_INSECURE=true
# SBOM_SERVER_URL="http://127.0.0.1:8765/api/sync/endpoints"
SBOM_AUTH_TOKEN="sdp_REPLACE_WITH_YOUR_TOKEN"
# Prefer this in production:
# SBOM_AUTH_TOKEN_FILE="/etc/sbom-inventory/token"

# Scan scope. The collector applies tiered default excludes automatically to
# every scan root: "/" gets the full OS-aware list; a home-directory root gets
# a cache tier (go module cache, cargo registry, ~/.cache, ...); every other
# root still skips VCS internals and __pycache__. The full "/" list covers pseudo
# filesystems, tmp/caches/trash, VCS internals (.git/.hg/.svn), __pycache__,
# container layer storage (covered by image scanning), snap/flatpak stores,
# package download caches (npm _cacache, cargo registry, the full go module
# cache, pnpm store, conda pkgs), system docs and headers (/usr/share
# doc/man/locale, /usr/include, apt lists),
# foreign/removable mounts (/mnt, /media — incl. WSL's Windows drive), boot
# and spool dirs, and on macOS the sealed system volume plus cloud-storage
# placeholders (never
# traversed — scanning them can trigger file downloads) and heavy Library
# paths. See default_exclude_paths_for_os in the script and the README "Full
# Filesystem Scans" table. Override by setting SBOM_EXCLUDE_PATHS (replaces
# the defaults entirely), or disable with SBOM_USE_DEFAULT_EXCLUDES=false.
#
# Default scope is user homes (/home on Linux, /Users on macOS) — developer
# dependency trees, fast scans. Uncomment for full-filesystem coverage that
# also inventories OS packages (dpkg/rpm/homebrew), /opt, and /usr/local:
# SBOM_SCAN_ROOTS="/"
# SBOM_SCAN_POLICY_VERSION="fullfs-v1"
# SBOM_EXCLUDE_PATHS="./proc/**:./sys/**:./dev/**:**/.git/**"
# SBOM_USE_DEFAULT_EXCLUDES=true

# Persistent local state. Use a managed, protected location in production.
SBOM_STATE_DIR="$HOME/.sbom-inventory"
SBOM_ENDPOINT_ID_FILE="$SBOM_STATE_DIR/endpoint-id"
SBOM_QUEUE_DIR="$SBOM_STATE_DIR/queue"
SBOM_RAW_DIR="$SBOM_STATE_DIR/raw"
SBOM_LOCK_DIR="$SBOM_STATE_DIR/run.lock"

# Stable policy/source labels sent to the server. Keep the policy label in
# sync with the scan scope (homes-v1 for the /home default, fullfs-v1 for /).
SBOM_SCAN_POLICY_VERSION="homes-v1"
SBOM_SOURCE_NAME="developer-endpoint"

# Output verbosity on stderr: quiet|info|verbose. The CLI --quiet/--verbose
# flags override this. Default: info.
# SBOM_LOG_LEVEL=info

# Frequent-run optimization: a cheap mtime sweep skips the full syft scan when
# nothing dependency-relevant changed; a forced full scan still happens every
# SBOM_FULL_SCAN_INTERVAL_HOURS as the coverage guarantee. Unchanged runs send
# one tiny heartbeat payload so the server still sees endpoint liveness.
SBOM_CHANGE_GATE=true
SBOM_FULL_SCAN_INTERVAL_HOURS=168
SBOM_HEARTBEAT_ON_UNCHANGED=true
# Extra absolute paths the sweep should watch (colon-separated):
# SBOM_GATE_EXTRA_PATHS="/opt/company-tools"

# Keep endpoint impact bounded. Adaptive parallelism raises syft workers toward
# half the CPU cores (capped) only when on AC power with low load. On macOS,
# taskpolicy -b runs the scanners at background QoS (the ionice equivalent).
SBOM_SYFT_PARALLELISM=2
SBOM_ADAPTIVE_PARALLELISM=true
SBOM_MAX_PARALLELISM=8
SBOM_NICE=10
SBOM_ENABLE_IONICE=true
SBOM_ENABLE_TASKPOLICY=true
SBOM_START_JITTER_SECONDS=0
SBOM_SKIP_ON_BATTERY=false
SBOM_MIN_FREE_MB=1024
SBOM_MAX_RUN_SECONDS=7200

# Optional load gate. Tune after measuring fleet behavior.
# SBOM_MAX_LOAD_1M=6

# Upload and queue controls.
SBOM_BATCH_SIZE=500
SBOM_MAX_BATCH_BYTES=2097152
SBOM_COMPRESS_UPLOAD=true
SBOM_TIMEOUT_SECONDS=30
SBOM_UPLOAD_RETRIES=2
SBOM_RETRY_DELAY_SECONDS=5
SBOM_QUEUE_RETRY_LIMIT=25
SBOM_MAX_QUEUE_FILES=10000
SBOM_MAX_QUEUE_BYTES=1073741824

# Raw Syft JSON is noisy and can be large. Keep it off by default.
SBOM_KEEP_RAW=false

# Strict config/token permission checks are ON by default: a token-bearing config
# or token file that is group/other readable or writable is REFUSED (fail closed).
# This checked-in example holds only placeholder token settings and may be world-
# readable in a public repo, so it opts out here. Delete this line (or set true) once
# you copy the config to a protected, owner-only path.
SBOM_STRICT_CONFIG_PERMS=false

# The config file is dot-sourced as shell, so anyone who can write it OR its parent
# directory can run code as the collector (a writable parent enables a TOCTOU file
# swap). By default we refuse to source a config that is group/world-writable or
# owned by someone other than you or root, or one whose parent directory is. Set
# true only for a deliberately shared-but-protected config.
SBOM_ALLOW_UNSAFE_CONFIG=false

# Full-filesystem mode should skip remote/pseudo mounts unless explicitly enabled.
# squashfs covers snap mounts; 9p/drvfs cover WSL's Windows drives; the rest
# are network or pseudo filesystems.
SBOM_SKIP_REMOTE_MOUNTS=true
SBOM_SKIP_FILESYSTEM_TYPES="proc,sysfs,devtmpfs,tmpfs,devfs,fdesc,autofs,nfs,nfs4,cifs,smbfs,sshfs,fuse.*,overlay,aufs,squashfs,tracefs,debugfs,securityfs,cgroup,cgroup2,pstore,bpf,nsfs,ramfs,9p,drvfs"

# Local fixture override for this repository:
#
# Uncomment these lines when testing only the checked-in fixture manifests.
#
# SBOM_DRY_RUN=true
# SBOM_SCAN_ROOTS="$PWD/test-manifests"
# SBOM_EXCLUDE_PATHS=""
# SBOM_BATCH_SIZE=4
# SBOM_START_JITTER_SECONDS=0
# SBOM_SKIP_ON_BATTERY=false
# SBOM_SOURCE_NAME="local-sbom-fixture"

# Optional aggressive excludes:
#
# These can reduce scan time and payload size, but they may miss legitimate
# installed dependency evidence. Keep them commented unless you have decided
# that manifests and lockfiles are sufficient for your inventory model.
#
# SBOM_EXCLUDE_PATHS="./proc/**:./sys/**:./dev/**:**/node_modules/**:**/.venv/**:**/venv/**:**/site-packages/**:**/vendor/**:**/target/**:**/build/**:**/dist/**"
