# SupplyDrift — copy to `.env` (gitignored) and adjust before `docker compose up -d`.

# ── Authentication ──────────────────────────────────────────────────────────
# Auth is ON by default. The first admin is seeded ONCE on an empty database from
# these two vars. Set a strong password BEFORE first boot — left empty, no admin
# is created (set it and restart to seed). Then log in at http://localhost:8765.
SUPPLYDRIFT_ADMIN_USER=admin
SUPPLYDRIFT_ADMIN_PASSWORD=

# Set to "disabled" to run with NO login (trusted local/dev network only).
SUPPLYDRIFT_AUTH=enabled

# Required to STORE source credentials (encrypts them at rest). Generate with:
#   python3 -c "import secrets,base64; print(base64.urlsafe_b64encode(secrets.token_bytes(32)).decode())"
# Keep it OUT of the database/backups. Losing it makes stored credentials unrecoverable.
SUPPLYDRIFT_SECRET_KEY=

# The runner<->platform token is generated automatically and shared over an internal
# volume — you do NOT need to set anything for the bundled compose runners.
# Only set this for an EXTERNAL runner that can't mount that volume (use a token you
# minted in the UI under Access -> API tokens, scope "runner"):
# SUPPLYDRIFT_RUNNER_TOKEN=sdp_...

# Optional local endpoint collector token. The scripts/local-compose.sh helper reads
# this value for `endpoint` scans. Create an API token with scope "ingest" in the UI.
# ENDPOINT_SCANNER_TOKEN=sdp_...

# ── Database (MySQL — the production datastore) ─────────────────────────────
# The compose `db` service and the platform both read these. Set both passwords —
# compose refuses to start while either is empty.
MYSQL_DATABASE=supplydrift
MYSQL_USER=supplydrift
MYSQL_PASSWORD=
MYSQL_ROOT_PASSWORD=
# The platform connects with: mysql+pymysql://${MYSQL_USER}:${MYSQL_PASSWORD}@db:3306/${MYSQL_DATABASE}
# To use SQLite instead (single-node/dev), remove SUPPLYDRIFT_DATABASE_URL from the
# platform service in docker-compose.yml.

# ── Optional ────────────────────────────────────────────────────────────────
# Public URL of the platform (used for CORS + Slack alert links).
# SUPPLYDRIFT_PUBLIC_URL=http://localhost:8765
# Slack webhook for malware alerts (the platform stores only the env-var NAME):
# SUPPLYDRIFT_SLACK_WEBHOOK=https://hooks.slack.com/services/XXX/YYY/ZZZ
# Host interface the platform port binds to. Defaults to 127.0.0.1 (localhost only);
# set 0.0.0.0 to expose on all interfaces (prefer fronting with a TLS proxy instead).
# BIND_ADDR=127.0.0.1
# Enable the destructive demo data routes (/api/demo/*). Off by default.
# SUPPLYDRIFT_DEMO=false
